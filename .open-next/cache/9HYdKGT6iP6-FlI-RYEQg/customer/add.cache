lass=\"h-1.5 w-20 bg-blue-600 mx-auto rounded-full\"></div></div><form class=\"space-y-8\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"space-y-2\"><label class=\"text-[10px] font-black text-slate-400 uppercase ml-1\">客户 / КЛИЕНТ</label><input required=\"\" class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 focus:bg-white focus:border-blue-500 outline-none transition-all font-bold\" placeholder=\"Archi / Ira / ...\" value=\"\"/></div><div class=\"space-y-2\"><label class=\"text-[10px] font-black text-slate-400 uppercase ml-1\">品名 / ТОВАР</label><input required=\"\" class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 focus:bg-white focus:border-blue-500 outline-none transition-all font-bold\" placeholder=\"衣服 / Электроника\" value=\"\"/></div></div><div class=\"space-y-2\"><label class=\"text-[10px] font-black text-slate-400 uppercase ml-1\">总货值 (¥) / СТОИМОСТЬ (RMB)</label><input required=\"\" type=\"number\" class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 focus:bg-white focus:border-blue-500 outline-none transition-all font-mono font-bold text-blue-600\" placeholder=\"1000\" value=\"\"/></div><div class=\"space-y-2\"><div class=\"flex justify-between items-center ml-1\"><label class=\"text-[10px] font-black text-slate-400 uppercase\">快递单号 / ТРЕК-НОМЕРА</label><span class=\"text-[10px] font-black bg-blue-50 text-blue-600 px-2 py-0.5 rounded-full uppercase\">0<!-- --> Items</span></div><textarea required=\"\" rows=\"5\" class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-3xl p-5 font-mono text-sm focus:bg-white focus:border-blue-500 outline-none transition-all leading-relaxed\" placeholder=\"在此粘贴多个单号，用回车或逗号分隔...\"></textarea></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"space-y-2\"><label class=\"text-[10px] font-black text-slate-400 uppercase ml-1\">发往仓库 / СКЛАД</label><select class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 font-bold outline-none focus:border-blue-500 transition-all\"><option value=\"Guangzhou\" selected=\"\">Гуанчжоу (Guangzhou)</option><option value=\"Yiwu\">Иу (Yiwu)</option></select></div><div class=\"space-y-2\"><label class=\"text-[10px] font-black text-slate-400 uppercase ml-1\">目的地 / ПУНКТ НАЗНАЧЕНИЯ</label><select class=\"w-full bg-slate-50 border-2 border-slate-50 rounded-2xl p-4 font-bold outline-none focus:border-blue-600 border-l-4 border-l-blue-600 transition-all\"><option value=\"Moscow\" selected=\"\">莫斯科 / Москва (Moscow)</option><option value=\"Almaty\">阿拉木图 / Алматы (Almaty)</option><option value=\"Uzbekistan\">乌兹别克斯坦 / Узбекистан (Uzbekistan)</option></select></div></div><button type=\"submit\" class=\"w-full text-white font-black py-5 rounded-[1.5rem] shadow-xl shadow-blue-200 transform active:scale-[0.98] transition-all text-lg uppercase tracking-wider bg-blue-600 hover:bg-blue-700\">提交预报 / ОТПРАВИТЬ</button></form></div></div></div><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-354563e8c2795753.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[2700,[\\\"177\\\",\\\"static/chunks/app/layout-8b8bc787adce00c2.js\\\"],\\\"LanguageProvider\\\"]\\n3:I[9766,[],\\\"\\\"]\\n4:I[8924,[],\\\"\\\"]\\n5:I[1959,[],\\\"ClientPageRoot\\\"]\\n6:I[9537,[\\\"63\\\",\\\"static/chunks/app/customer/add/page-c9b40133b3b9b064.js\\\"],\\\"default\\\"]\\n9:I[4431,[],\\\"OutletBoundary\\\"]\\nb:I[5278,[],\\\"AsyncMetadataOutlet\\\"]\\nd:I[4431,[],\\\"ViewportBoundary\\\"]\\nf:I[4431,[],\\\"MetadataBoundary\\\"]\\n10:\\\"$Sreact.suspense\\\"\\n12:I[7150,[],\\\"\\\"]\\n:HL[\\\"/_next/static/css/20855577e4d6bce6.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"9HYdKGT6iP6-FlI-RYEQg\\\",\\\"p\\\":\\\"\\\",\\\"c\\\":[\\\"\\\",\\\"customer\\\",\\\"add\\\"],\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"cust